# Copie este arquivo para ".env" e preencha com as credenciais do seu
# projeto Supabase (Project Settings → API).
#
# Estas variáveis são lidas pelo Vite em build/dev (import.meta.env).
# Como começam com VITE_, elas vão para o bundle do navegador — use
# apenas a anon/publishable key aqui, NUNCA a service role key.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key-aqui

# Chave de API do Google Maps (Maps JavaScript API + Geocoding API +
# Directions API habilitadas no Google Cloud Console). Como é uma SPA,
# esta chave fica visível no navegador — restrinja por domínio (HTTP
# referrer) no Google Cloud para evitar uso indevido.
VITE_GOOGLE_MAPS_API_KEY=sua-chave-do-google-maps-aqui
